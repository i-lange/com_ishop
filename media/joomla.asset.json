{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "com_ishop",
  "version": "1.0.22",
  "description": "com_ishop Assets",
  "license": "GNU General Public License version 2 or later",
  "assets": [
    {
      "name": "com_ishop.admin",
      "type": "style",
      "uri": "com_ishop/admin.css"
    },
    {
      "name": "com_ishop.admin-filter",
      "type": "script",
      "uri": "com_ishop/admin-filter.js",
      "dependencies": ["core"],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_ishop.admin-modal-items",
      "type": "script",
      "uri": "com_ishop/admin-modal-items.js",
      "dependencies": ["core", "joomla.dialog"],
      "attributes": {
        "type": "module"
      }
    },
    {
      "name": "com_ishop.front",
      "type": "style",
      "uri": "com_ishop/front.css"
    },
    {
      "name": "com_ishop.cart",
      "type": "script",
      "uri": "com_ishop/cart.js",
      "dependencies": ["core"],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_ishop.addtocart",
      "type": "script",
      "uri": "com_ishop/addtocart.js",
      "dependencies": ["core"],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_ishop.addtocompare",
      "type": "script",
      "uri": "com_ishop/addtocompare.js",
      "dependencies": ["core"],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_ishop.addtowishlist",
      "type": "script",
      "uri": "com_ishop/addtowishlist.js",
      "dependencies": ["core"],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_ishop.products-loader",
      "type": "script",
      "uri": "com_ishop/products-loader.js",
      "dependencies": ["core"],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_ishop.admin-product-batch",
      "type": "script",
      "uri": "com_ishop/admin-product-batch.js",
      "dependencies": [
        "com_ishop.admin-product-batch.es5"
      ],
      "attributes": {
        "type": "module"
      }
    },
    {
      "name": "com_ishop.admin-product-batch.es5",
      "type": "script",
      "uri": "com_ishop/admin-product-batch-es5.js",
      "dependencies": [
        "core"
      ],
      "attributes": {
        "nomodule": true,
        "defer": true
      }
    }
  ]
}
