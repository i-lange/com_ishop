<?xml version="1.0" encoding="utf-8"?>
<form>
    <config>
        <inlinehelp button="show"/>
    </config>
    <fieldset name="details" label="COM_ISHOP_FORM_DETAILS"
              addfieldprefix="Ilange\Component\Ishop\Administrator\Field">
        <field name="id"
               type="text"
               default="0"
               readonly="true"
               class="readonly"
               label="JGLOBAL_FIELD_ID_LABEL"/>
        <field name="title"
               type="text"
               required="true"
               maxlength="255"
               label="COM_ISHOP_FIELD_TITLE"/>
        <field name="alias"
               type="text"
               label="JFIELD_ALIAS_LABEL"
               description="JFIELD_ALIAS_DESC"
               hint="JFIELD_ALIAS_PLACEHOLDER"/>
        <field name="state"
               type="list"
               label="JSTATUS"
               class="form-select-color-state"
               default="1"
               validate="options">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="2">JARCHIVED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field name="introtext"
               type="textarea"
               label="COM_ISHOP_FIELD_INTROTEXT"
               rows="3"
               cols="30"
               maxlength="500"
               charcounter="true"/>
        <field name="fulltext"
               type="editor"
               label="COM_ISHOP_FIELD_FULLTEXT"
               filter="\Joomla\CMS\Component\ComponentHelper::filterText"
               buttons="no"/>
        <field name="type"
               type="list"
               label="COM_ISHOP_FIELD_TYPE"
               default="1"
               validate="options">
            <option value="0">COM_ISHOP_FIELD_TYPE_PSEUDO</option>
            <option value="1">COM_ISHOP_FIELD_TYPE_REAL</option>
            <option value="2">COM_ISHOP_FIELD_TYPE_CODE</option>
        </field>
        <field name="percent"
               type="text"
               filter="float"
               required="true"
               label="COM_ISHOP_FIELD_PERCENT"
               min="0.01"
               max="99.99"/>
        <field name="code"
               type="text"
               label="COM_ISHOP_FIELD_PROMO_CODE"
               showon="type:2"/>
        <field name="products"
               type="products"
               multiple="true"
               validate="options"
               label="COM_ISHOP_FIELD_PRODUCTS"/>
        <field name="cats"
               type="category"
               label="JCATEGORY"
               multiple="true"
               extension="com_ishop"
               layout="joomla.form.field.list-fancy-select"
               hint="JOPTION_SELECT_CATEGORY"
               class="js-select-submit-on-change"
               published="1"/>
        <field name="manufacturers"
               type="manufacturers"
               multiple="true"
               validate="options"
               label="COM_ISHOP_FIELD_MANUFACTURER"/>
        <field name="suppliers"
               type="suppliers"
               multiple="true"
               validate="options"
               label="COM_ISHOP_FIELD_IMPORTER"/>
        <field name="min_price"
               type="text"
               filter="float"
               label="COM_ISHOP_FIELD_MIN_PRICE"/>
        <field name="min_amount"
               type="text"
               filter="float"
               label="COM_ISHOP_FIELD_MIN_AMOUNT"/>
        <field name="created"
               type="calendar"
               label="COM_ISHOP_FIELD_CREATED_LABEL"
               translateformat="true"
               showtime="true"
               filter="user_utc"/>
        <field name="created_by"
               type="user"
               label="COM_ISHOP_FIELD_CREATED_BY_LABEL"
               validate="UserId"/>
        <field name="created_by_alias"
               type="text"
               label="COM_ISHOP_FIELD_CREATED_BY_ALIAS_LABEL"/>
        <field name="modified"
               type="calendar"
               label="JGLOBAL_FIELD_MODIFIED_LABEL"
               class="form-control"
               translateformat="true"
               showtime="true"
               readonly="true"
               filter="user_utc"/>
        <field name="modified_by"
               type="user"
               label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
               class="readonly"
               readonly="true"
               filter="unset"
               validate="UserId"/>
        <field name="checked_out"
               type="hidden"
               filter="unset"/>
        <field name="checked_out_time"
               type="hidden"
               filter="unset"/>
        <field name="ordering"
               type="text"
               label="JFIELD_ORDERING_LABEL"
               default="0"/>
    </fieldset>
    <fields name="images" label="COM_ISHOP_FIELD_IMAGE_OPTIONS">
        <fieldset name="image-small" label="COM_ISHOP_FIELD_IMAGE_SMALL_LABEL">
            <field name="image_small"
                   type="media"
                   schemes="http,https,ftp,ftps,data,file"
                   validate="url"
                   relative="true"
                   label="COM_ISHOP_FIELD_IMAGE_SMALL_LABEL"/>
            <field name="image_small_alt"
                   type="text"
                   label="COM_ISHOP_FIELD_IMAGE_ALT_LABEL"/>
        </fieldset>
        <fieldset name="image-main" label="COM_ISHOP_FIELD_IMAGE_MAIN_LABEL">
            <field name="image_main"
                   type="media"
                   schemes="http,https,ftp,ftps,data,file"
                   validate="url"
                   relative="true"
                   label="COM_ISHOP_FIELD_IMAGE_MAIN_LABEL"/>
            <field name="image_main_alt"
                   type="text"
                   label="COM_ISHOP_FIELD_IMAGE_ALT_LABEL"/>
        </fieldset>
    </fields>
</form>
