<?xml version="1.0" encoding="utf-8"?>
<form>
    <config>
        <inlinehelp button="show"/>
    </config>
    <fieldset name="details" label="COM_ISHOP_FORM_DETAILS"
              addfieldprefix="Ilange\Component\Ishop\Administrator\Field">
        <field name="id"
               type="text"
               default="0"
               readonly="true"
               class="readonly"
               label="JGLOBAL_FIELD_ID_LABEL"/>
        <field name="title"
               type="text"
               required="true"
               maxlength="255"
               label="COM_ISHOP_FIELD_TITLE"/>
        <field name="alias"
               type="text"
               label="JFIELD_ALIAS_LABEL"
               description="JFIELD_ALIAS_DESC"
               hint="JFIELD_ALIAS_PLACEHOLDER"/>
        <field name="state"
               type="list"
               label="JSTATUS"
               class="form-select-color-state"
               default="1"
               validate="options">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="2">JARCHIVED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field name="introtext"
               type="textarea"
               label="COM_ISHOP_FIELD_INTROTEXT"
               rows="3"
               cols="30"
               maxlength="500"
               charcounter="true"/>
        <field name="fulltext"
               type="editor"
               label="COM_ISHOP_FIELD_FULLTEXT"
               filter="\Joomla\CMS\Component\ComponentHelper::filterText"
               buttons="no"/>
        <field name="bitrix24_id"
               type="number"
               label="COM_ISHOP_FIELD_BITRIX24_ZONE"
               min="0"
               default=""/>
        <field name="created"
               type="calendar"
               label="COM_ISHOP_FIELD_CREATED_LABEL"
               translateformat="true"
               showtime="true"
               filter="user_utc"/>
        <field name="created_by"
               type="user"
               label="COM_ISHOP_FIELD_CREATED_BY_LABEL"
               validate="UserId"/>
        <field name="created_by_alias"
               type="text"
               label="COM_ISHOP_FIELD_CREATED_BY_ALIAS_LABEL"/>
        <field name="modified"
               type="calendar"
               label="JGLOBAL_FIELD_MODIFIED_LABEL"
               class="form-control"
               translateformat="true"
               showtime="true"
               readonly="true"
               filter="user_utc"/>
        <field name="modified_by"
               type="user"
               label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
               class="readonly"
               readonly="true"
               filter="unset"
               validate="UserId"/>
        <field name="checked_out"
               type="hidden"
               filter="unset"/>
        <field name="checked_out_time"
               type="hidden"
               filter="unset"/>
        <field name="ordering"
               type="text"
               label="JFIELD_ORDERING_LABEL"
               default="0"/>
    </fieldset>
    <field name="attribs"
           type="subform"
           label="COM_ISHOP_FIELD_PARAMS_ZONE">
        <form>
            <field name="exec-time"
                   type="time"
                   label="COM_ISHOP_FIELD_WAREHOUSES_TODAY_TIME"/>
            <field name="warehouses_default_days"
                   type="number"
                   default="0"
                   required="true"
                   min="0"
                   max="1000"
                   validate="number"
                   label="COM_ISHOP_FIELD_WAREHOUSES_DEFAULT_DAYS"/>
            <field name="suppliers_default_days"
                   type="number"
                   default="0"
                   required="true"
                   min="0"
                   max="1000"
                   validate="number"
                   label="COM_ISHOP_FIELD_SUPPLIERS_DEFAULT_DAYS"/>
            <field name="default_orders"
                   type="number"
                   default="0"
                   required="true"
                   min="1"
                   max="100000"
                   validate="number"
                   label="COM_ISHOP_FIELD_DEFAULT_ORDERS"/>
            <field name="calendar"
                   type="list"
                   label="COM_ISHOP_FIELD_CALENDAR_DAYS"
                   default=""
                   multiple="true"
                   layout="joomla.form.field.list-fancy-select"
                   validate="options">
                <option value="0">SUNDAY</option>
                <option value="1">MONDAY</option>
                <option value="2">TUESDAY</option>
                <option value="3">WEDNESDAY</option>
                <option value="4">THURSDAY</option>
                <option value="5">FRIDAY</option>
                <option value="6">SATURDAY</option>
            </field>
            <field name="intervals_delivery"
                   type="list"
                   label="COM_ISHOP_FIELD_INTERVALS_DELIVERY"
                   multiple="true"
                   default=""
                   required="true"
                   validate="options"
                   layout="joomla.form.field.list-fancy-select">
                <option value="4625">COM_ISHOP_FIELD_INTERVAL_0</option>
                <option value="4591">COM_ISHOP_FIELD_INTERVAL_1</option>
                <option value="4593">COM_ISHOP_FIELD_INTERVAL_2</option>
            </field>
            <field name="suppliers_delivery"
                   type="subform"
                   label="COM_ISHOP_FIELD_SUPPLIERS_DELIVERY"
                   multiple="true"
                   layout="joomla.form.field.subform.repeatable-table">
                <form>
                    <field name="supplier"
                           type="suppliers"
                           default="0"
                           required="true"
                           validate="options"
                           label="COM_ISHOP_FIELD_SUPPLIER"/>
                    <field name="days"
                           type="number"
                           default="0"
                           required="true"
                           max="1000"
                           validate="number"
                           label="COM_ISHOP_FIELD_DAYS_LABEL"/>
                </form>
            </field>
            <field name="warehouses_delivery"
                   type="subform"
                   label="COM_ISHOP_FIELD_WAREHOUSES_DELIVERY"
                   multiple="true"
                   layout="joomla.form.field.subform.repeatable-table">
                <form>
                    <field name="warehouse"
                           type="warehouses"
                           default="0"
                           required="true"
                           validate="options"
                           label="COM_ISHOP_FIELD_WAREHOUSE"/>
                    <field name="days"
                           type="number"
                           default="0"
                           required="true"
                           max="1000"
                           validate="number"
                           label="COM_ISHOP_FIELD_DAYS_LABEL"/>
                </form>
            </field>
        </form>
    </field>
    <field name="current"
           type="subform"
           multiple="true"
           label="COM_ISHOP_FIELD_PARAMS_ZONE"
           layout="joomla.form.field.subform.repeatable-table">
        <form>
            <field name="date"
                   type="calendar"
                   required="true"
                   label="COM_ISHOP_FIELD_DELIVERY_DATE"
                   translateformat="true"
                   showtime="false"/>
            <field name="interval"
                   type="list"
                   label="COM_ISHOP_FIELD_INTERVAL"
                   default="0"
                   required="true"
                   validate="options">
                <option value="4625">COM_ISHOP_FIELD_INTERVAL_0</option>
                <option value="4591">COM_ISHOP_FIELD_INTERVAL_1</option>
                <option value="4593">COM_ISHOP_FIELD_INTERVAL_2</option>
            </field>
            <field name="count"
                   type="number"
                   default="0"
                   required="true"
                   max="1000"
                   validate="number"
                   label="COM_ISHOP_FIELD_COUNT"/>
        </form>
    </field>
    <fields name="images" label="COM_ISHOP_FIELD_IMAGE_OPTIONS">
        <fieldset name="image-small" label="COM_ISHOP_FIELD_IMAGE_SMALL_LABEL">
            <field name="image_small"
                   type="media"
                   schemes="http,https,ftp,ftps,data,file"
                   validate="url"
                   relative="true"
                   label="COM_ISHOP_FIELD_IMAGE_SMALL_LABEL"/>
            <field name="image_small_alt"
                   type="text"
                   label="COM_ISHOP_FIELD_IMAGE_ALT_LABEL"/>
        </fieldset>
        <fieldset name="image-main" label="COM_ISHOP_FIELD_IMAGE_MAIN_LABEL">
            <field name="image_main"
                   type="media"
                   schemes="http,https,ftp,ftps,data,file"
                   validate="url"
                   relative="true"
                   label="COM_ISHOP_FIELD_IMAGE_MAIN_LABEL"/>
            <field name="image_main_alt"
                   type="text"
                   label="COM_ISHOP_FIELD_IMAGE_ALT_LABEL"/>
        </fieldset>
    </fields>
</form>
