<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Ilange\Component\Ishop\Administrator\Field">
    <fields name="filter">
        <field name="search"
               type="text"
               label="COM_ISHOP_FILTER_SEARCH"
               description="COM_ISHOP_FILTER_SEARCH_DESC"
               hint="JSEARCH_FILTER"/>
        <field name="featured"
               type="list"
               default=""
               validate="options"
               class="js-select-submit-on-change"
               label="JFEATURED">
            <option value="">COM_ISHOP_FILTER_FEATURED</option>
            <option value="0">COM_ISHOP_FILTER_FEATURED_NO</option>
            <option value="1">COM_ISHOP_FILTER_FEATURED_YES</option>
        </field>
        <field name="published"
               type="status"
               extension="com_ishop"
               class="js-select-submit-on-change"
               label="JOPTION_SELECT_PUBLISHED">
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>
        <field name="category_id"
               type="category"
               label="JCATEGORY"
               multiple="true"
               extension="com_ishop"
               published="0,1,2"
               class="js-select-submit-on-change"
               layout="joomla.form.field.list-fancy-select"
               hint="JOPTION_SELECT_CATEGORY"/>
        <field name="level"
               type="integer"
               label="JGLOBAL_MAXLEVEL_LABEL"
               first="1"
               last="10"
               step="1"
               languages="*"
               class="js-select-submit-on-change">
            <option value="">JOPTION_SELECT_MAX_LEVELS</option>
        </field>
        <field name="access"
               type="accesslevel"
               multiple="true"
               class="js-select-submit-on-change"
               layout="joomla.form.field.list-fancy-select"
               label="JGRID_HEADING_ACCESS"
               hint="JOPTION_SELECT_ACCESS"/>
        <field name="author_id"
               type="author"
               multiple="true"
               layout="joomla.form.field.list-fancy-select"
               class="js-select-submit-on-change"
               label="JOPTION_SELECT_AUTHOR"
               hint="JOPTION_SELECT_AUTHOR">
            <option value="0">JNONE</option>
            <option value="by_me">COM_ISHOP_FILTER_AUTHORS_BY_ME</option>
        </field>
        <field name="language"
               type="contentlanguage"
               class="js-select-submit-on-change"
               label="JGRID_HEADING_LANGUAGE">
            <option value="">JOPTION_SELECT_LANGUAGE</option>
            <option value="*">JALL</option>
        </field>
        <field name="tag"
               type="tag"
               multiple="true"
               mode="nested"
               custom="false"
               class="js-select-submit-on-change"
               label="JTAG"
               hint="JOPTION_SELECT_TAG"/>
        <field name="stock"
               type="list"
               class="js-select-submit-on-change"
               label="COM_ISHOP_FILTER_STOCK"
               hint="COM_ISHOP_FILTER_STOCK_HINT">
            <option value="">COM_ISHOP_FILTER_STOCK_SELECT</option>
            <option value="0">COM_ISHOP_FILTER_STOCK_NO</option>
            <option value="1">COM_ISHOP_FILTER_STOCK_YES</option>
        </field>
        <field name="manufacturer"
               type="manufacturers"
               multiple="true"
               class="js-select-submit-on-change"
               label="COM_ISHOP_FILTER_MANUFACTURER"
               hint="COM_ISHOP_FILTER_MANUFACTURER_HINT">
        </field>
        <field name="prefix"
               type="prefixes"
               multiple="true"
               class="js-select-submit-on-change"
               label="COM_ISHOP_FILTER_PREFIX"
               hint="COM_ISHOP_FILTER_PREFIX_HINT">
        </field>
    </fields>
    <fields name="list">
        <field name="fullordering"
               type="list"
               default="a.id DESC"
               validate="options"
               class="js-select-submit-on-change"
               label="JGLOBAL_SORT_BY">
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.ordering ASC">JGRID_HEADING_ORDERING_ASC</option>
            <option value="a.ordering DESC">JGRID_HEADING_ORDERING_DESC</option>
            <option value="a.featured ASC">JFEATURED_ASC</option>
            <option value="a.featured DESC">JFEATURED_DESC</option>
            <option value="a.state ASC">JSTATUS_ASC</option>
            <option value="a.state DESC">JSTATUS_DESC</option>
            <option value="a.title ASC">COM_ISHOP_FILTER_MODEL_ASC</option>
            <option value="a.title DESC">COM_ISHOP_FILTER_MODEL_DESC</option>
            <option value="a.price ASC">COM_ISHOP_FILTER_PRICE_ASC</option>
            <option value="a.price DESC">COM_ISHOP_FILTER_PRICE_DESC</option>
            <option value="category_title ASC">JCATEGORY_ASC</option>
            <option value="category_title DESC">JCATEGORY_DESC</option>
            <option value="a.access ASC">JGRID_HEADING_ACCESS_ASC</option>
            <option value="a.access DESC">JGRID_HEADING_ACCESS_DESC</option>
            <option value="a.created_by ASC">JAUTHOR_ASC</option>
            <option value="a.created_by DESC">JAUTHOR_DESC</option>
            <option value="association ASC" requires="associations">JASSOCIATIONS_ASC</option>
            <option value="association DESC" requires="associations">JASSOCIATIONS_DESC</option>
            <option value="language ASC" requires="multilanguage">JGRID_HEADING_LANGUAGE_ASC</option>
            <option value="language DESC" requires="multilanguage">JGRID_HEADING_LANGUAGE_DESC</option>
            <option value="a.created ASC">JDATE_ASC</option>
            <option value="a.created DESC">JDATE_DESC</option>
            <option value="a.publish_up ASC">COM_ISHOP_PUBLISH_UP_ASC</option>
            <option value="a.publish_up DESC">COM_ISHOP_PUBLISH_UP_DESC</option>
            <option value="a.publish_down ASC">COM_ISHOP_PUBLISH_DOWN_ASC</option>
            <option value="a.publish_down DESC">COM_ISHOP_PUBLISH_DOWN_DESC</option>
            <option value="a.hits ASC">JGLOBAL_HITS_ASC</option>
            <option value="a.hits DESC">JGLOBAL_HITS_DESC</option>
            <option value="rating_count ASC">JGLOBAL_VOTES_ASC</option>
            <option value="rating_count DESC">JGLOBAL_VOTES_DESC</option>
            <option value="rating ASC">JGLOBAL_RATINGS_ASC</option>
            <option value="rating DESC">JGLOBAL_RATINGS_DESC</option>
            <option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
        </field>
        <field name="limit"
               type="limitbox"
               default="25"
               class="js-select-submit-on-change"
               label="JGLOBAL_LIST_LIMIT"/>
    </fields>
</form>
