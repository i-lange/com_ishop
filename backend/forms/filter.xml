<?xml version="1.0" encoding="utf-8"?>
<form>
    <config>
        <inlinehelp button="show"/>
    </config>
    <fieldset name="details" label="COM_ISHOP_FORM_DETAILS"
              addfieldprefix="Ilange\Component\Ishop\Administrator\Field">
        <field name="id"
               type="text"
               default="0"
               readonly="true"
               class="readonly"
               label="JGLOBAL_FIELD_ID_LABEL"/>
        <field name="category_id"
               type="category"
               extension="com_ishop"
               required="true"
               label="JCATEGORY"
               hint="JOPTION_SELECT_CATEGORY"
               published="1"/>
        <field name="state"
               type="list"
               label="JSTATUS"
               class="form-select-color-state"
               default="1"
               validate="options">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="2">JARCHIVED</option>
            <option value="-2">JTRASHED</option>
        </field>
        <field name="manufacturers"
               type="manufacturers"
               multiple="true"
               validate="options"
               label="COM_ISHOP_FIELD_MANUFACTURER"/>
        <field name="ishop_fields"
               type="filterfields"
               label="COM_ISHOP_FILTER_FIELD_VALUES"
               description="COM_ISHOP_FILTER_FIELD_VALUES_DESC"/>
        <field name="min_width"
               type="number"
               min="0"
               default="0"
               filter="integer"
               label="COM_ISHOP_FIELD_MIN_WIDTH"/>
        <field name="max_width"
               type="number"
               min="0"
               default="0"
               filter="integer"
               label="COM_ISHOP_FIELD_MAX_WIDTH"/>
        <field name="min_height"
               type="number"
               min="0"
               default="0"
               filter="integer"
               label="COM_ISHOP_FIELD_MIN_HEIGHT"/>
        <field name="max_height"
               type="number"
               min="0"
               default="0"
               filter="integer"
               label="COM_ISHOP_FIELD_MAX_HEIGHT"/>
        <field name="min_depth"
               type="number"
               min="0"
               default="0"
               filter="integer"
               label="COM_ISHOP_FIELD_MIN_DEPTH"/>
        <field name="max_depth"
               type="number"
               min="0"
               default="0"
               filter="integer"
               label="COM_ISHOP_FIELD_MAX_DEPTH"/>
        <field name="min_weight"
               type="number"
               min="0"
               default="0"
               filter="integer"
               label="COM_ISHOP_FIELD_MIN_WEIGHT"/>
        <field name="max_weight"
               type="number"
               min="0"
               default="0"
               filter="integer"
               label="COM_ISHOP_FIELD_MAX_WEIGHT"/>
        <field name="description"
               type="editor"
               label="JGLOBAL_DESCRIPTION"
               filter="\Joomla\CMS\Component\ComponentHelper::filterText"
               buttons="true"
               hide="readmore,pagebreak"/>
        <field name="metatitle"
               type="text"
               maxlength="255"
               label="COM_ISHOP_FIELD_META_TITLE"/>
        <field name="metadesc"
               type="textarea"
               rows="3"
               cols="60"
               label="JFIELD_META_DESCRIPTION_LABEL"/>
        <field name="metakey"
               type="textarea"
               rows="3"
               cols="60"
               label="JFIELD_META_KEYWORDS_LABEL"/>
        <field name="created"
               type="calendar"
               label="COM_ISHOP_FIELD_CREATED_LABEL"
               translateformat="true"
               showtime="true"
               filter="user_utc"/>
        <field name="created_by"
               type="user"
               label="COM_ISHOP_FIELD_CREATED_BY_LABEL"
               validate="UserId"/>
        <field name="created_by_alias"
               type="text"
               label="COM_ISHOP_FIELD_CREATED_BY_ALIAS_LABEL"/>
        <field name="modified"
               type="calendar"
               label="JGLOBAL_FIELD_MODIFIED_LABEL"
               class="form-control"
               translateformat="true"
               showtime="true"
               readonly="true"
               filter="user_utc"/>
        <field name="modified_by"
               type="user"
               label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
               class="readonly"
               readonly="true"
               filter="unset"
               validate="UserId"/>
        <field name="checked_out"
               type="hidden"
               filter="unset"/>
        <field name="checked_out_time"
               type="hidden"
               filter="unset"/>
        <field name="ordering"
               type="text"
               label="JFIELD_ORDERING_LABEL"
               default="0"/>
        <field name="language"
               type="contentlanguage"
               label="JFIELD_LANGUAGE_LABEL">
            <option value="*">JALL</option>
        </field>
    </fieldset>
</form>
