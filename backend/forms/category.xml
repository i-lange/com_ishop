<?xml version="1.0" encoding="UTF-8"?>
<form addfieldprefix="Ilange\Component\Ishop\Administrator\Field">
    <field name="title"
           type="text"
           required="true"
           class="form-control-lg"
           label="JGLOBAL_TITLE"
           description="JGLOBAL_LIST_TITLE_LABEL"
           horizontal="true"/>
    <field name="alias"
           type="text"
           class="form-control-lg"
           label="JFIELD_ALIAS_LABEL"
           description="JFIELD_ALIAS_DESC"
           hint="JFIELD_ALIAS_PLACEHOLDER"/>
    <field name="description"
           type="editor"
           label="JGLOBAL_DESCRIPTION"
           description="COM_ISHOP_CATEGORY_DESCRIPTION_DESC"
           hiddenDescription='true'
           filter="\Joomla\CMS\Component\ComponentHelper::filterText"
           buttons="true"
           hide="readmore,pagebreak"/>
    <field name="parent_id"
           type="categorytree"
           required="true"
           default="1"
           label="COM_ISHOP_CATEGORY_PARENT_LABEL"
           description="COM_ISHOP_CATEGORY_PARENT_DESC"/>
    <field name="published"
           type="list"
           default="1"
           label="JSTATUS"
           description="JFIELD_PUBLISHED_DESC">
        <option value="1">JPUBLISHED</option>
        <option value="0">JUNPUBLISHED</option>
        <option value="2">JARCHIVED</option>
        <option value="-2">JTRASHED</option>
    </field>
    <field name="access"
           type="accesslevel"
           label="JFIELD_ACCESS_LABEL"
           description="JFIELD_ACCESS_DESC"/>
    <field name="language"
           type="contentlanguage"
           label="JFIELD_LANGUAGE_LABEL"
           description="COM_ISHOP_CATEGORY_LANGUAGE_DESC">
        <option value="*">JALL</option>
    </field>
    <field name="note"
           type="text"
           maxlength="255"
           label="JFIELD_NOTE_LABEL"
           description="JFIELD_NOTE_DESC"/>
    <field name="version_note"
           type="text"
           maxlength="255"
           label="JGLOBAL_FIELD_VERSION_NOTE_LABEL"
           description="JGLOBAL_FIELD_VERSION_NOTE_DESC"/>
    <field name="created_time"
           type="calendar"
           label="JGLOBAL_CREATED_DATE"
           filter="user_utc"
           translateformat="true"
           showtime="true"/>
    <field name="created_user_id"
           type="user"
           label="JGLOBAL_FIELD_CREATED_BY_LABEL"
           description="JGLOBAL_FIELD_CREATED_BY_DESC"/>
    <field name="modified_time"
           type="calendar"
           readonly="true"
           label="JGLOBAL_FIELD_MODIFIED_LABEL"
           filter="user_utc"
           translateformat="true"
           showtime="true"/>
    <field name="modified_user_id"
           type="user"
           label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
           readonly="true"
           filter="unset"/>
    <field name="hits"
           type="number"
           label="JGLOBAL_HITS"
           default="0"
           readonly="true"/>
    <field name="id"
           type="number"
           default="0"
           readonly="true"
           label="JGLOBAL_FIELD_ID_LABEL"
           description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="metadesc"
           type="textarea"
           label="JFIELD_META_DESCRIPTION_LABEL"
           description="JFIELD_META_DESCRIPTION_DESC"/>
    <field name="metakey"
           type="textarea"
           label="JFIELD_META_KEYWORDS_LABEL"
           description="JFIELD_META_KEYWORDS_DESC"/>
    <field name="checked_out"
           type="hidden"
           filter="unset"/>
    <field name="checked_out_time"
           type="hidden"
           filter="unset"/>
    <field name="rules"
           type="rules"
           id="rules"
           label="JFIELD_RULES_LABEL"
           translate_label="false"
           filter="rules"
           validate="rules"
           component="com_ishop"
           section="category"/>
    <field name="asset_id"
           type="hidden"
           filter="unset"
           label="JFIELD_ASSET_ID_LABEL"/>
    <field name="lft"
           type="hidden"
           filter="unset"/>
    <field name="rgt"
           type="hidden"
           filter="unset"/>
    <field name="level"
           type="hidden"
           filter="unset"/>
    <field name="path"
           type="text"
           readonly="true"
           label="CATEGORIES_PATH_LABEL"
           description="CATEGORIES_PATH_DESC"/>
    <field name="extension"
           type="hidden"/>


    <fields name="params">
        <fieldset name="options">
            <fieldset name="basic" label="COM_ISHOP_BASIC_PARAMETERS_LABEL">
                <field name="image"
                       type="media"
                       label="COM_ISHOP_CATEGORY_IMAGE_LABEL"
                       description="COM_ISHOP_CATEGORY_IMAGE_DESC"/>
                <field name="image_alt"
                       type="text"
                       label="COM_ISHOP_CATEGORY_IMAGE_ALT_LABEL"
                       description="COM_ISHOP_CATEGORY_IMAGE_ALT_DESC"/>
                <field name="image_alt_empty"
                       type="checkbox"
                       label="COM_ISHOP_CATEGORY_IMAGE_ALT_EMPTY_LABEL"
                       description="COM_ISHOP_CATEGORY_IMAGE_ALT_EMPTY_DESC"/>
                <field name="category_layout"
                       type="componentlayout"
                       label="JFIELD_ALT_LAYOUT_LABEL"
                       description="JFIELD_ALT_COMPONENT_LAYOUT_DESC"
                       view="category"
                       useglobal="true"
                       class="form-select"/>
            </fieldset>
            <fieldset name="export_options">
                <field name="export_text"
                       type="textarea"
                       label="COM_ISHOP_CATEGORY_EXPORT_TEXT"
                       rows="3"
                       cols="30"
                       maxlength="500"
                       charcounter="true"/>
            </fieldset>
            <fieldset name="fields_options">
                <field name="filter_fields"
                       type="sql"
                       label="COM_ISHOP_CATEGORY_FILTER_FIELDS"
                       multiple="true"
                       layout="joomla.form.field.list-fancy-select"
                       query="select `id`, `title` as name from `#__ishop_fields` where `state` = 1 order by `id` ASC"
                       key_field="id"
                       value_field="name"/>
                <field name="fields_groups"
                       type="subform"
                       label="COM_ISHOP_CATEGORY_FIELDS_GROUPS"
                       multiple="true"
                       layout="joomla.form.field.subform.repeatable-table">
                    <form>
                        <field name="group"
                               type="sql"
                               required="true"
                               label="COM_ISHOP_FIELD_GROUP"
                               multiple="false"
                               layout="joomla.form.field.list-fancy-select"
                               query="select `id`, `title` as name from `#__ishop_groups` where `state` = 1 order by `id` ASC"
                               key_field="id"
                               value_field="name"/>
                        <field name="field"
                               type="sql"
                               required="true"
                               label="COM_ISHOP_FIELD_FIELD"
                               multiple="true"
                               layout="joomla.form.field.list-fancy-select"
                               query="select `id`, `title` as name from `#__ishop_fields` where `state` = 1 order by `id` ASC"
                               key_field="id"
                               value_field="name"/>
                    </form>
                </field>
            </fieldset>
        </fieldset>
    </fields>

    <fields name="metadata" label="JGLOBAL_FIELDSET_METADATA_OPTIONS">
        <fieldset name="jmetadata" label="JGLOBAL_FIELDSET_METADATA_OPTIONS">
            <field name="author"
                   type="text"
                   label="JAUTHOR"
                   description="JFIELD_METADATA_AUTHOR_DESC"/>
            <field name="robots"
                   type="list"
                   label="JFIELD_METADATA_ROBOTS_LABEL"
                   description="JFIELD_METADATA_ROBOTS_DESC">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="index, follow">JGLOBAL_INDEX_FOLLOW</option>
                <option value="noindex, follow">JGLOBAL_NOINDEX_FOLLOW</option>
                <option value="index, nofollow">JGLOBAL_INDEX_NOFOLLOW</option>
                <option value="noindex, nofollow">JGLOBAL_NOINDEX_NOFOLLOW</option>
            </field>
        </fieldset>
    </fields>
</form>
