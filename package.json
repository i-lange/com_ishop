{
  "name": "com_ishop",
  "version": "1.0.0",
  "author": {
    "name": "Pavel Lange",
    "email": "pavel@ilange.ru",
    "url": "https://ilange.ru"
  },
  "private": true,
  "type": "module",
  "license": "GPL-2.0-or-later",
  "description": "E-commerce Component for CMS Joomla! v6",
  "keywords": [
    "joomla",
    "joomla 6",
    "joomla-component",
    "ecommerce",
    "ishop"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i-lange/com_ishop.git"
  },
  "bugs": {
    "url": "https://github.com/i-lange/com_ishop/issues"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "> 0.5%"
  ],
  "main": "",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "stylelint": "^17.4.0",
    "vite": "^8.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:css": "vite --config vite.config.css.mts",
    "dev:js": "vite --config vite.config.js.mts",
    "build": "node build.mjs",
    "build:css": "vite build --config vite.config.css.mts",
    "build:js": "vite build --config vite.config.js.mts",
    "preview": "vite preview",
    "lint": "eslint \"media/js/**/*.js\"",
    "lint:css": "stylelint \"media/scss/**/*.scss\"",
    "format": "prettier --write \"{media,backend,frontend}/**/*.{js,scss,css,php,xml,ini}\"",
    "test": "echo \"No automated tests yet\" && exit 0"
  },
  "packageManager": "pnpm@10.3.0",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.8.0",
    "pnpm": ">=10.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js"
    ]
  }
}
